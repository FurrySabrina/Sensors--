{
    // Exclude cache files from being indexed
    "files.exclude": {
        //"**/Cache": true
    },
    // fixes files to properly convert into proper languages
    "files.associations": {
        "*.json": "jsonc", // fixes json being interpreted as jsonc because SM supports jsonc
        "*.rend": "jsonc",
        "*.blueprint": "jsonc",
        "*.effectset": "jsonc",
        "*.effectdb": "jsonc",
        "*.layout": "xml",
        "*.harvestableset": "jsonc",
        "*.harvestabledb": "jsonc",
        "*.kinematicset": "jsonc",
        "*.kinematicdb": "jsonc",
        "*.shapeset": "jsonc",
        "*.rotationset": "jsonc",
        "*.shapedb": "jsonc",
        "*.projectileset": "jsonc",
        "*.sobset": "jsonc",
        "*.sobdb": "jsonc",
        "*.world": "jsonc",
        "*.toolset": "jsonc",
        "*.tooldb": "jsonc",
    },
    "material-icon-theme.folders.color": "#df7f00",
    "material-icon-theme.files.color": "#df7f00",
    "material-icon-theme.folders.theme": "specific",
    "material-icon-theme.files.associations": {
        // Renderable files
        "*.rend": "rend", // rend

        // MTL files
        "*.mtl": "3d",
        
        // Blueprints JSONs
        "*.blueprint": "blueprint",

        // TCO Compressed Textures
        "*.tco": "image",

        // Characters JSONs
        "*.characterset": "characterset",
        "*.characterdb": "characterdb",

        // Effects JSONs
        "*.effectset": "effectset",
        "*.effectdb": "effectdb",

        // Layouts
        "*.layout": "layout",

        // Harvestables
        "*.harvestableset": "harvestableset",
        "*.harvestabledb": "harvestabledb",

        // Kinematics
        "*.kinematicset": "kinematicset",
        "*.kinematicdb": "kinematicdb",

        // Objects
        "*.shapeset": "shapeset",
        "*.rotationset": "rotationset",
        "*.shapedb": "shapedb",

        // Particles
        "particles.json": "particles",

        // Prefabs
        "*.prefab": "prefab",

        // Projectiles
        "*.projectileset": "projectileset",

        // Scriptable Objects
        "*.sobset": "sobset",
        "*.sobdb": "sobdb",

        // Terrain
        "*.assetset": "assetset",
        "*.assetdb": "assetdb",
        "*.tile": "tile",
        "*.tile.export": "tile-export",
        "*.world": "world",

        // Tools
        "*.toolset": "toolset",
        "*.tooldb": "tooldb",

        // Description
        "description.json": "description",
    },
    "material-icon-theme.files.customClones": [
        // VSCode
        {
            "name": "VSCode settings",
            "base": "vscode",
            "color": "light-blue-800",
            "fileNames": [".vscode/settings.json"]
        }
    ],
    "material-icon-theme.folders.customClones": [

        // Accidental iconed folders
        {
            "name": "Accidentally iconed folders",
            "base": "folder",
            "color": "#df7f00",
            "lightColor": "#df7f00",
            "folderNames": ["moon", "torch", "game","managers"]
        },
    ],
